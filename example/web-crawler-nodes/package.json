{
  "name": "@leafergraph/web-crawler-nodes",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build:esm": "node ./scripts/prepare_dist.mjs && tsc -p tsconfig.build.json && vite build",
    "build:browser": "vite build --config vite.browser.config.ts",
    "build": "bun run build:esm && bun run build:browser"
  },
  "peerDependencies": {
    "@leafergraph/authoring": "workspace:*",
    "@leafergraph/contracts": "workspace:*",
    "@leafergraph/node": "workspace:*",
    "leafer-ui": "^2.0.3"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^5.0.0"
  }
}