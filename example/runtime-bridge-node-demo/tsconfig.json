{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["vite/client"],
    "paths": {
      "@leafergraph/authoring": ["../../packages/authoring/src/index.ts"],
      "@leafergraph/basic-kit": ["../../packages/basic-kit/src/index.ts"],
      "@leafergraph/config": ["../../packages/config/src/index.ts"],
      "@leafergraph/contracts": ["../../packages/contracts/src/index.ts"],
      "@leafergraph/contracts/graph-document-diff": [
        "../../packages/contracts/src/graph_document_diff.ts"
      ],
      "@leafergraph/diff": ["../../packages/diff/src/index.ts"],
      "@leafergraph/execution": ["../../packages/execution/src/index.ts"],
      "@leafergraph/node": ["../../packages/node/src/index.ts"],
      "@leafergraph/runtime-bridge": ["../../packages/runtime-bridge/src/index.ts"],
      "@leafergraph/runtime-bridge/client": [
        "../../packages/runtime-bridge/src/client/index.ts"
      ],
      "@leafergraph/runtime-bridge/portable": [
        "../../packages/runtime-bridge/src/portable/index.ts"
      ],
      "@leafergraph/runtime-bridge/transport": [
        "../../packages/runtime-bridge/src/transport/index.ts"
      ],
      "@leafergraph/theme": ["../../packages/theme/src/index.ts"],
      "@leafergraph/widget-runtime": [
        "../../packages/widget-runtime/src/index.ts"
      ],
      "leafergraph": ["../../packages/leafergraph/src/index.ts"]
    }
  },
  "include": ["src/client", "src/shared", "src/server", "vite.config.ts"]
}
