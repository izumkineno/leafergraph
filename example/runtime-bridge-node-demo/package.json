{
  "name": "leafergraph-runtime-bridge-node-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "bun run ./src/server/dev.ts",
    "bench:diff-modes": "bun run ./src/server/bench_diff_modes.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && bun run build:client && bun run build:server",
    "check": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "bun test ./tests"
  },
  "dependencies": {
    "@happy-dom/global-registrator": "^20.0.10",
    "@leafergraph/authoring": "workspace:*",
    "@leafergraph/basic-kit": "workspace:*",
    "@leafergraph/context-menu": "workspace:*",
    "@leafergraph/context-menu-builtins": "workspace:*",
    "@leafergraph/contracts": "workspace:*",
    "@leafergraph/execution": "workspace:*",
    "@leafergraph/node": "workspace:*",
    "@leafergraph/runtime-bridge": "workspace:*",
    "@leafergraph/shortcuts": "workspace:*",
    "@leafergraph/undo-redo": "workspace:*",
    "@leafergraph/widget-runtime": "workspace:*",
    "leafer-ui": "^2.0.3",
    "leafergraph": "workspace:*",
    "preact": "^10.29.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
