{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "frontend_bundle_source.schema.json",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "bundleId",
        "name",
        "slot",
        "fileName",
        "enabled",
        "sha256",
        "format",
        "sourceCode"
      ],
      "properties": {
        "bundleId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slot": {
          "enum": [
            "node",
            "widget"
          ]
        },
        "fileName": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sha256": {
          "type": "string"
        },
        "format": {
          "const": "script"
        },
        "sourceCode": {
          "type": "string"
        },
        "quickCreateNodeType": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "bundleId",
        "name",
        "slot",
        "fileName",
        "enabled",
        "sha256",
        "format",
        "definition"
      ],
      "properties": {
        "bundleId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slot": {
          "const": "node"
        },
        "fileName": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sha256": {
          "type": "string"
        },
        "format": {
          "const": "node-json"
        },
        "definition": {
          "$ref": "./graph_node_definition.schema.json"
        },
        "quickCreateNodeType": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "bundleId",
        "name",
        "slot",
        "fileName",
        "enabled",
        "sha256",
        "format",
        "document"
      ],
      "properties": {
        "bundleId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slot": {
          "const": "demo"
        },
        "fileName": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sha256": {
          "type": "string"
        },
        "format": {
          "const": "demo-json"
        },
        "document": {
          "$ref": "./graph_document.schema.json"
        }
      },
      "additionalProperties": false
    }
  ]
}
