{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "frontend_bundle_package.schema.json",
  "type": "object",
  "required": [
    "packageId",
    "version",
    "nodeTypes",
    "bundles"
  ],
  "properties": {
    "packageId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "nodeTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bundles": {
      "type": "array",
      "items": {
        "$ref": "./frontend_bundle_source.schema.json"
      }
    }
  },
  "additionalProperties": false
}
