{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_control_request.schema.json",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "type",
        "nodeId"
      ],
      "properties": {
        "type": {
          "const": "node.play"
        },
        "nodeId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "graph.play",
            "graph.step",
            "graph.stop"
          ]
        }
      },
      "additionalProperties": false
    }
  ]
}
