{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph_node_definition.schema.json",
  "type": "object",
  "required": [
    "type"
  ],
  "properties": {
    "type": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "./graph_node_slot_spec.schema.json"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "./graph_node_slot_spec.schema.json"
      }
    },
    "properties": {
      "type": "array",
      "items": {
        "$ref": "./graph_node_property_spec.schema.json"
      }
    },
    "widgets": {
      "type": "array",
      "items": {
        "$ref": "./graph_node_widget_spec.schema.json"
      }
    },
    "size": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "resize": {
      "$ref": "./graph_node_resize.schema.json"
    },
    "minWidth": {
      "type": "number"
    },
    "minHeight": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
