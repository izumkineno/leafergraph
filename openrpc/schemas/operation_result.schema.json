{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "operation_result.schema.json",
  "type": "object",
  "required": [
    "accepted",
    "changed",
    "revision"
  ],
  "properties": {
    "accepted": {
      "type": "boolean"
    },
    "changed": {
      "type": "boolean"
    },
    "revision": {
      "type": [
        "string",
        "number"
      ]
    },
    "reason": {
      "type": "string"
    },
    "document": {
      "$ref": "./graph_document.schema.json"
    }
  },
  "additionalProperties": false
}
