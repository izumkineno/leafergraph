{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph_document_diff.schema.json",
  "type": "object",
  "required": [
    "documentId",
    "baseRevision",
    "revision",
    "emittedAt",
    "operations",
    "fieldChanges"
  ],
  "properties": {
    "documentId": {
      "type": "string"
    },
    "baseRevision": {
      "type": [
        "string",
        "number"
      ]
    },
    "revision": {
      "type": [
        "string",
        "number"
      ]
    },
    "emittedAt": {
      "type": "number"
    },
    "operations": {
      "type": "array",
      "items": {
        "$ref": "./graph_operation.schema.json"
      }
    },
    "fieldChanges": {
      "type": "array",
      "items": {
        "$ref": "./graph_document_field_change.schema.json"
      }
    }
  },
  "additionalProperties": false
}
