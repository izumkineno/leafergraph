{
  "name": "leafergraph-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shell": "./src/shell/index.ts",
    "./ui": "./src/ui.ts",
    "./ui/foundation": "./src/ui/foundation/index.ts",
    "./ui/titlebar": "./src/ui/titlebar/index.ts",
    "./ui/workspace": "./src/ui/workspace/index.ts",
    "./ui/node-library": "./src/ui/node-library/index.ts",
    "./ui/viewport": "./src/ui/viewport/index.ts",
    "./ui/inspector": "./src/ui/inspector/index.ts",
    "./ui/statusbar": "./src/ui/statusbar/index.ts",
    "./ui/workspace-settings": "./src/ui/workspace-settings/index.ts",
    "./ui/run-console": "./src/ui/run-console/index.ts",
    "./ui/node-library-preview": "./src/ui/node-library-preview/index.ts",
    "./backend": "./src/backend.ts",
    "./styles.css": "./src/styles.css",
    "./ui/foundation/styles.css": "./src/ui/foundation/styles.css",
    "./ui/titlebar/styles.css": "./src/ui/titlebar/styles.css",
    "./ui/workspace/styles.css": "./src/ui/workspace/styles.css",
    "./ui/node-library/styles.css": "./src/ui/node-library/styles.css",
    "./ui/viewport/styles.css": "./src/ui/viewport/styles.css",
    "./ui/inspector/styles.css": "./src/ui/inspector/styles.css",
    "./ui/statusbar/styles.css": "./src/ui/statusbar/styles.css",
    "./ui/workspace-settings/styles.css": "./src/ui/workspace-settings/styles.css",
    "./ui/run-console/styles.css": "./src/ui/run-console/styles.css",
    "./ui/node-library-preview/styles.css": "./src/ui/node-library-preview/styles.css"
  },
  "scripts": {
    "generate:authority-openrpc": "bun ./tools/generate_from_openrpc.ts",
    "check:authority-openrpc": "bun ./tools/generate_from_openrpc.ts --check",
    "dev": "bun run generate:authority-openrpc && vite",
    "dev:lan": "bun run generate:authority-openrpc && vite --mode lan --host 0.0.0.0",
    "build": "bun run generate:authority-openrpc && tsc && vite build",
    "preview": "vite preview",
    "test:unit": "bun run generate:authority-openrpc && bun test ./tests",
    "test:e2e:preview": "bun run build && playwright test --config=playwright.config.ts --project=preview",
    "test:e2e:python": "bun run build && playwright test --config=playwright.config.ts --project=python",
    "test": "bun run test:unit && bun run test:e2e:preview"
  },
  "dependencies": {
    "leafergraph": "0.1.0",
    "preact": "^10.26.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@preact/preset-vite": "^2.10.2",
    "preact-render-to-string": "^6.5.13"
  }
}
