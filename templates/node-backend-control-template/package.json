    "dev": "bun run ./src/server.ts",
    "test": "bun test ./tests"
  },
  "dependencies": {
    "@leafergraph/node": "file:../../packages/node",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "typescript": "~5.9.3"
  }
}
