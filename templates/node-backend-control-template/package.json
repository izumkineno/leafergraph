{
  "name": "@template/node-backend-control-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/server.js",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "bun build ./src/server.ts --outfile ./dist/server.js --target node --format esm",
