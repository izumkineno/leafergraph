{
  "name": "@template/node-widget-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build:esm": "node ./scripts/prepare_dist.mjs && tsc -p tsconfig.build.json && vite build",
    "build:browser": "vite build --config vite.browser.config.ts --mode demo && vite build --config vite.browser.config.ts --mode demo-alt && vite build --config vite.browser.config.ts --mode node && vite build --config vite.browser.config.ts --mode widget",
    "build": "bun run build:esm && bun run build:browser"
  },
  "peerDependencies": {
    "@leafergraph/node": "^0.1.0",
    "leafer-ui": "^2.0.3",
    "leafergraph": "^0.1.0"
  },
  "devDependencies": {
    "@leafergraph/node": "file:../../packages/node",
    "leafer-ui": "^2.0.3",
    "leafergraph": "file:../../packages/leafergraph",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
