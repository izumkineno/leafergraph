{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_feedback_node_state_event.schema.json",
  "type": "object",
  "required": [
    "type",
    "event"
  ],
  "properties": {
    "type": {
      "const": "node.state"
    },
    "event": {
      "type": "object",
      "required": [
        "nodeId",
        "exists",
        "reason",
        "timestamp"
      ],
      "properties": {
        "nodeId": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "reason": {
          "enum": [
            "created",
            "updated",
            "removed",
            "moved",
            "resized",
            "collapsed",
            "connections",
            "widget-value",
            "widget-action",
            "input-values",
            "execution"
          ]
        },
        "timestamp": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
