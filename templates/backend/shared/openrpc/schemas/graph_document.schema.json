{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graph_document.schema.json",
  "type": "object",
  "required": [
    "documentId",
    "revision",
    "appKind",
    "nodes",
    "links"
  ],
  "properties": {
    "documentId": {
      "type": "string"
    },
    "revision": {
      "type": [
        "string",
        "number"
      ]
    },
    "appKind": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "./graph_node.schema.json"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "./graph_link.schema.json"
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "capabilityProfile": {
      "$ref": "./capability_profile.schema.json"
    },
    "adapterBinding": {
      "$ref": "./adapter_binding.schema.json"
    }
  },
  "additionalProperties": false
}
