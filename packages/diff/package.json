{
  "name": "@leafergraph/diff",
  "version": "1.0.0",
  "description": "LeaferGraph diff functionality package",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && bun run build:esm",
    "build:esm": "bun build src/index.ts --outfile dist/index.mjs --format esm",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run build --watch"
  },
  "dependencies": {
    "@leafergraph/contracts": "workspace:*",
    "@leafergraph/node": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "leafer",
    "graph",
    "diff",
    "node",
    "graph-diff"
  ],
  "author": "Leafer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leaferjs/leafergraph"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}