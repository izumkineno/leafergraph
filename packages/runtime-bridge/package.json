{
  "name": "@leafergraph/runtime-bridge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts"
    },
    "./portable": {
      "types": "./src/portable/index.ts",
      "import": "./src/portable/index.ts"
    },
    "./execution": {
      "types": "./src/execution/index.ts",
      "import": "./src/execution/index.ts"
    },
    "./extensions": {
      "types": "./src/extensions/index.ts",
      "import": "./src/extensions/index.ts"
    },
    "./transport": {
      "types": "./src/transport/index.ts",
      "import": "./src/transport/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test ./tests"
  },
  "dependencies": {
    "@leafergraph/contracts": "workspace:*",
    "@leafergraph/execution": "workspace:*",
    "@leafergraph/node": "workspace:*",
    "leafergraph": "workspace:*"
  }
