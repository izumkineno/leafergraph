    "@leafergraph/theme": "workspace:*",
    "@leafergraph/widget-runtime": "workspace:*",
    "@leafer-in/arrow": "^2.0.3",
    "@leafer-in/find": "^2.0.3",
    "@leafer-in/flow": "^2.0.3",
    "@leafer-in/resize": "^2.0.3",
    "@leafer-in/state": "^2.0.3",
    "@leafer-in/view": "^2.0.3",
    "@leafer-in/viewport": "^2.0.3",
    "leafer-ui": "^2.0.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.10"
