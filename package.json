{
  "name": "leafergraph-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:editor": "bun run --filter leafergraph-editor dev",
    "dev:editor:lan": "bun run --filter leafergraph-editor dev:lan",
    "build:testbundles": "node ./scripts/build_editor_testbundles.mjs",
    "build:node": "bun run --filter @leafergraph/node build",
    "check:node-backend": "bun run --cwd ./templates/node-backend-template check",
    "build:node-backend": "bun run --cwd ./templates/node-backend-template build",
    "dev:node-backend": "bun run --cwd ./templates/node-backend-template dev",
    "start:node-backend": "bun run --cwd ./templates/node-backend-template start",
    "test:node-backend": "bun run --cwd ./templates/node-backend-template test",
    "build:leafergraph": "bun run --filter leafergraph build",
    "build:editor": "bun run --filter leafergraph-editor build",
    "build": "bun run build:node && bun run build:leafergraph && bun run build:editor",
    "preview:editor": "bun run --filter leafergraph-editor preview",
    "start:python-backend": "uv run --project templates/python-backend-template python -m leafergraph_python_backend_control_template.entry",
    "test:python-backend": "uv run --project templates/python-backend-template python -m pytest templates/python-backend-template/tests"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
