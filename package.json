{
  "name": "leafergraph-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*",
    "example/*",
    "templates/node/authoring-node-template",
    "templates/widget/authoring-text-widget-template",
    "templates/misc/authoring-browser-plugin-template"
  ],
  "scripts": {
    "dev:editor": "bun run --filter leafergraph-editor dev",
    "dev:editor:lan": "bun run --filter leafergraph-editor dev:lan",
    "dev:minimal-graph": "bun run --filter leafergraph-minimal-graph-example dev",
    "dev:authoring-basic-nodes": "bun run --filter leafergraph-authoring-basic-nodes-example dev",
    "generate:editor-authority-openrpc": "bun run --filter leafergraph-editor generate:authority-openrpc",
    "check:editor-authority-openrpc": "bun run --filter leafergraph-editor check:authority-openrpc",
    "build:testbundles": "node ./scripts/build_editor_testbundles.mjs",
    "build:node": "bun run --filter @leafergraph/node build",
    "build:execution": "bun run --filter @leafergraph/execution build",
    "build:authoring": "bun run --filter @leafergraph/authoring build",
    "build:context-menu": "bun run --filter @leafergraph/context-menu build",
    "build:leafergraph": "bun run --filter leafergraph build",
    "build:sync": "bun run --filter @leafergraph/sync build",
    "build:editor": "bun run --filter leafergraph-editor build",
    "build:minimal-graph": "bun run --filter leafergraph-minimal-graph-example build",
    "build:authoring-basic-nodes": "bun run --filter leafergraph-authoring-basic-nodes-example build",
    "build": "bun run build:node && bun run build:execution && bun run build:authoring && bun run build:context-menu && bun run build:leafergraph && bun run build:sync && bun run build:editor",
    "test:authoring": "bun run --filter @leafergraph/authoring test",
    "test:context-menu": "bun run --filter @leafergraph/context-menu test",
    "test:sync": "bun run --filter @leafergraph/sync test",
    "preview:editor": "bun run --filter leafergraph-editor preview",
    "preview:minimal-graph": "bun run --filter leafergraph-minimal-graph-example preview",
    "preview:authoring-basic-nodes": "bun run --filter leafergraph-authoring-basic-nodes-example preview",
    "test:editor": "bun run --filter leafergraph-editor test",
    "test:editor:unit": "bun run --filter leafergraph-editor test:unit",
    "test:editor:e2e:preview": "bun run --filter leafergraph-editor test:e2e:preview",
    "test:editor:e2e:python": "bun run --filter leafergraph-editor test:e2e:python",
    "test:authority-conformance:assets": "uv run --project templates/backend/python-openrpc-authority-template pytest templates/backend/python-openrpc-authority-template/tests/test_conformance_assets.py",
    "test:authority-conformance:runner": "uv run --project templates/backend/python-openrpc-authority-template pytest templates/backend/python-openrpc-authority-template/tests/test_conformance_runner.py",
    "test:authority-conformance": "bun run test:authority-conformance:assets && bun run test:authority-conformance:runner",
    "start:python-backend": "uv run --project templates/backend/python-openrpc-authority-template python -m leafergraph_python_openrpc_authority_template.entry",
    "test:python-backend": "uv run --project templates/backend/python-openrpc-authority-template python -m pytest templates/backend/python-openrpc-authority-template/tests",
    "start:python-openrpc-backend": "uv run --project templates/backend/python-openrpc-authority-template python -m leafergraph_python_openrpc_authority_template.entry",
    "test:python-openrpc-backend": "uv run --project templates/backend/python-openrpc-authority-template python -m pytest templates/backend/python-openrpc-authority-template/tests"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
