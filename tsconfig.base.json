{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@leafergraph/core/node": ["packages/core/node/src/index.ts"],
      "@leafergraph/core/node/*": ["packages/core/node/src/*"],
      "@leafergraph/core/execution": ["packages/core/execution/src/index.ts"],
      "@leafergraph/core/execution/*": ["packages/core/execution/src/*"],
      "@leafergraph/core/contracts": ["packages/core/contracts/src/index.ts"],
      "@leafergraph/core/contracts/*": ["packages/core/contracts/src/*"],
      "@leafergraph/core/config": ["packages/core/config/src/index.ts"],
      "@leafergraph/core/config/*": ["packages/core/config/src/*"],
      "@leafergraph/core/theme": ["packages/core/theme/src/index.ts"],
      "@leafergraph/core/theme/*": ["packages/core/theme/src/*"],
      "@leafergraph/core/widget-runtime": ["packages/core/widget-runtime/src/index.ts"],
      "@leafergraph/core/widget-runtime/*": ["packages/core/widget-runtime/src/*"],
      "@leafergraph/core/basic-kit": ["packages/core/basic-kit/src/index.ts"],
      "@leafergraph/core/basic-kit/*": ["packages/core/basic-kit/src/*"],
      "@leafergraph/extensions/context-menu": ["packages/extensions/context-menu/src/index.ts"],
      "@leafergraph/extensions/context-menu/*": ["packages/extensions/context-menu/src/*"],
      "@leafergraph/extensions/context-menu-builtins": [
        "packages/extensions/context-menu-builtins/src/index.ts"
      ],
      "@leafergraph/extensions/context-menu-builtins/*": [
        "packages/extensions/context-menu-builtins/src/*"
      ],
      "@leafergraph/extensions/undo-redo": ["packages/extensions/undo-redo/src/index.ts"],
      "@leafergraph/extensions/undo-redo/*": ["packages/extensions/undo-redo/src/*"],
      "@leafergraph/extensions/shortcuts": ["packages/extensions/shortcuts/src/index.ts"],
      "@leafergraph/extensions/shortcuts/*": ["packages/extensions/shortcuts/src/*"],
      "@leafergraph/extensions/authoring": ["packages/extensions/authoring/src/index.ts"],
      "@leafergraph/extensions/authoring/*": ["packages/extensions/authoring/src/*"],
      "@leafergraph/node": ["packages/core/node/src/index.ts"],
      "@leafergraph/node/*": ["packages/core/node/src/*"],
      "@leafergraph/execution": ["packages/core/execution/src/index.ts"],
      "@leafergraph/execution/*": ["packages/core/execution/src/*"],
      "@leafergraph/contracts": ["packages/core/contracts/src/index.ts"],
      "@leafergraph/contracts/*": ["packages/core/contracts/src/*"],
      "@leafergraph/config": ["packages/core/config/src/index.ts"],
      "@leafergraph/config/*": ["packages/core/config/src/*"],
      "@leafergraph/theme": ["packages/core/theme/src/index.ts"],
      "@leafergraph/theme/*": ["packages/core/theme/src/*"],
      "@leafergraph/widget-runtime": ["packages/core/widget-runtime/src/index.ts"],
      "@leafergraph/widget-runtime/*": ["packages/core/widget-runtime/src/*"],
      "@leafergraph/basic-kit": ["packages/core/basic-kit/src/index.ts"],
      "@leafergraph/basic-kit/*": ["packages/core/basic-kit/src/*"],
      "@leafergraph/context-menu": ["packages/extensions/context-menu/src/index.ts"],
      "@leafergraph/context-menu/*": ["packages/extensions/context-menu/src/*"],
      "@leafergraph/context-menu-builtins": ["packages/extensions/context-menu-builtins/src/index.ts"],
      "@leafergraph/context-menu-builtins/*": ["packages/extensions/context-menu-builtins/src/*"],
      "@leafergraph/undo-redo": ["packages/extensions/undo-redo/src/index.ts"],
      "@leafergraph/undo-redo/*": ["packages/extensions/undo-redo/src/*"],
      "@leafergraph/shortcuts": ["packages/extensions/shortcuts/src/index.ts"],
      "@leafergraph/shortcuts/*": ["packages/extensions/shortcuts/src/*"],
      "@leafergraph/authoring": ["packages/extensions/authoring/src/index.ts"],
      "@leafergraph/authoring/*": ["packages/extensions/authoring/src/*"],
      "leafergraph": ["packages/leafergraph/src/index.ts"],
      "leafergraph/*": ["packages/leafergraph/src/*"]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
